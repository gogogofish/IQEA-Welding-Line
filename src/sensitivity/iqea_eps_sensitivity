def plot_epsilon_sensitivity_clouds(all_epsilon_fronts, epsilon_labels, out_dir):
    """并排绘制不同 epsilon 设置下的帕累托点云（CT vs QLoss，颜色表示 LoadSTD）"""
    plt.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']
    plt.rcParams['axes.unicode_minus'] = False
    n = len(epsilon_labels)
    fig, axes = plt.subplots(1, n, figsize=(5 * n, 4), squeeze=False)
    axes = axes[0]
    all_ct = []
    all_ql = []
    for label in epsilon_labels:
        points = all_epsilon_fronts.get(label, [])
        if points:
            pts = np.array(points)
            all_ct.extend(pts[:, 0])
            all_ql.extend(pts[:, 2])
    if all_ct and all_ql:
        ct_min, ct_max = min(all_ct), max(all_ct)
        ql_min, ql_max = min(all_ql), max(all_ql)
        ct_pad = max(1.0, 0.05 * (ct_max - ct_min + 1e-9))
        ql_pad = max(1e-3, 0.05 * (ql_max - ql_min + 1e-12))
    else:
        ct_min = ql_min = 0.0
        ct_max = ql_max = 1.0
        ct_pad = ql_pad = 0.1
    for ax, label in zip(axes, epsilon_labels):
        ax.set_title(label)
        ax.set_xlabel("CT (s)")
        ax.set_ylabel("QLoss")
        points = all_epsilon_fronts.get(label, [])
        if points:
            pts = np.array(points)
            ct_vals = pts[:, 0]
            std_vals = pts[:, 1]
            qloss_vals = pts[:, 2]
            sc = ax.scatter(ct_vals, qloss_vals, c=std_vals, s=50, alpha=0.85,
                            edgecolors='black', linewidths=0.4, cmap='viridis')
            if ax is axes[0]:
                cbar = plt.colorbar(sc, ax=ax, fraction=0.046, pad=0.04)
                cbar.set_label('LoadSTD (s)')
        else:
            ax.text(0.5, 0.5, "无非支配解", ha='center', va='center', transform=ax.transAxes)
        ax.grid(True, alpha=0.3)
        ax.set_xlim(ct_min - ct_pad, ct_max + ct_pad)
        ax.set_ylim(ql_min - ql_pad, ql_max + ql_pad)
    fig.suptitle("不同 ε 容忍参数下的最终帕累托点云 (CT vs QLoss, 颜色=LoadSTD)", fontsize=14, fontweight='bold')
    plt.tight_layout()
    plot_path = os.path.join(out_dir, 'epsilon_sensitivity_pareto_clouds.png')
    plt.savefig(plot_path, dpi=300, bbox_inches='tight')
