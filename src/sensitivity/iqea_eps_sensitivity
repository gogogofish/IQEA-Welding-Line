def get_environment_info():
    return {
        "python_version": sys.version.replace("\n", " "),
        "platform": platform.platform(),
        "processor": platform.processor(),
        "machine": platform.machine(),
        "numpy_version": np.__version__,
    }

def save_environment_info(out_dir: str) -> str:
    os.makedirs(out_dir, exist_ok=True)
    path = os.path.join(out_dir, "environment_info.json")
    with open(path, "w", encoding="utf-8") as f:
        json.dump(get_environment_info(), f, indent=2, ensure_ascii=False)
    return path

def parse_epsilon_settings(text: str):
    settings = []
    for item in text.split(","):
        item = item.strip()
        if not item:
            continue
        label, ct, std = item.split(":")
        settings.append((label.strip(), float(ct), float(std)))
    return settings

def parse_args():
    parser = argparse.ArgumentParser(
        description="GitHub-ready epsilon sensitivity experiment for the welding-line three-objective IQEA."
    )
    parser.add_argument(
        "--epsilon-settings",
        type=str,
        default="eps_025:0.25:0.125,eps_05:0.50:0.25,eps_1:1.00:0.50,eps_2:2.00:1.00",
        help="Comma-separated label:eps_ct:eps_std triples.",
    )
    parser.add_argument("--num-runs", type=int, default=20)
    parser.add_argument("--pop-size", type=int, default=30)
    parser.add_argument("--max-iter", type=int, default=100)
    parser.add_argument("--n-obs-base", type=int, default=3)
    parser.add_argument("--base-seed", type=int, default=20260)
    parser.add_argument("--out-dir", type=str, default="results/iqea_epsilon_sensitivity")
    parser.add_argument("--no-plots", action="store_true")
    return parser.parse_args()

def main():
    args = parse_args()
    epsilon_settings = parse_epsilon_settings(args.epsilon_settings)
    os.makedirs(args.out_dir, exist_ok=True)
    env_path = save_environment_info(args.out_dir)

    if args.no_plots:
        globals()["plot_epsilon_sensitivity_clouds"] = lambda *a, **k: None
        globals()["plot_hv_igd_boxplots"] = lambda *a, **k: None
        globals()["plot_parallel_coordinates"] = lambda *a, **k: None

    results = run_epsilon_sensitivity(
        epsilon_settings=epsilon_settings,
        num_runs=args.num_runs,
        pop_size=args.pop_size,
        max_iter=args.max_iter,
        n_obs_base=args.n_obs_base,
        base_seed=args.base_seed,
        out_dir=args.out_dir,
    )

    config_path = os.path.join(args.out_dir, "experiment_config.json")
    with open(config_path, "w", encoding="utf-8") as f:
        json.dump(
            {
                "epsilon_settings": epsilon_settings,
                "num_runs": args.num_runs,
                "pop_size": args.pop_size,
                "max_iter": args.max_iter,
                "n_obs_base": args.n_obs_base,
                "base_seed": args.base_seed,
                "out_dir": args.out_dir,
                "plots_enabled": not args.no_plots,
            },
            f,
            indent=2,
            ensure_ascii=False,
        )

    print("=" * 90)
    print("IQEA epsilon sensitivity experiment completed.")
    print(f"Output directory : {os.path.abspath(args.out_dir)}")
    print(f"Run details CSV  : {results['run_csv']}")
    print(f"Summary CSV      : {results['summary_csv']}")
    print(f"Reference CSV    : {results['norm_csv']}")
    print(f"Environment JSON : {env_path}")
    print(f"Config JSON      : {config_path}")
    print("=" * 90)

if __name__ == "__main__":
    main()
