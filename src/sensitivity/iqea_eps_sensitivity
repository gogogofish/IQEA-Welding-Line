def plot_parallel_coordinates(run_records, epsilon_labels, out_dir):
    """绘制三目标平行坐标图（分面：每个 epsilon 一个子图）"""
    plt.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']
    plt.rcParams['axes.unicode_minus'] = False
    n = len(epsilon_labels)
    fig, axes = plt.subplots(1, n, figsize=(5 * n, 4), sharey=False, squeeze=False)
    axes = axes[0]
    # 收集所有目标的范围用于统一归一化
    all_ct, all_std, all_ql = [], [], []
    for rec in run_records:
        if not np.isnan(rec['CT']):
            all_ct.append(rec['CT'])
            all_std.append(rec['LoadSTD'])
            all_ql.append(rec['QLoss'])
    if not all_ct:
        return
    ct_min, ct_max = min(all_ct), max(all_ct)
    std_min, std_max = min(all_std), max(all_std)
    ql_min, ql_max = min(all_ql), max(all_ql)
    # 归一化函数
    def norm(v, lo, hi):
        if hi - lo < EPS:
            return 0.5
        return (v - lo) / (hi - lo)
    for ax, label in zip(axes, epsilon_labels):
        records = [rec for rec in run_records if rec['label'] == label and not np.isnan(rec['CT'])]
        if not records:
            ax.text(0.5, 0.5, "无数据", ha='center', va='center', transform=ax.transAxes)
            ax.set_title(label)
            continue
        # 为每条线分配透明度或颜色（这里用浅灰色，按 QLoss 映射颜色可选）
        for rec in records:
            ct_n = norm(rec['CT'], ct_min, ct_max)
            std_n = norm(rec['LoadSTD'], std_min, std_max)
            ql_n = norm(rec['QLoss'], ql_min, ql_max)
            ax.plot(['CT', 'LoadSTD', 'QLoss'], [ct_n, std_n, ql_n],
                    color='steelblue', alpha=0.4, linewidth=0.8)
        # 添加平均值线
        avg_ct = norm(np.mean([r['CT'] for r in records]), ct_min, ct_max)
        avg_std = norm(np.mean([r['LoadSTD'] for r in records]), std_min, std_max)
        avg_ql = norm(np.mean([r['QLoss'] for r in records]), ql_min, ql_max)
        ax.plot(['CT', 'LoadSTD', 'QLoss'], [avg_ct, avg_std, avg_ql],
                color='red', linewidth=2, label='Average Values')
        ax.set_title(label)
        ax.set_xlabel("Objective")
        ax.set_ylabel("Normalized objective value")
        ax.set_ylim(0, 1)
        ax.grid(True, alpha=0.3)
        if ax is axes[0]:
            ax.legend()
    fig.suptitle("不同 ε 设置下最终解的三目标平行坐标图（归一化）", fontsize=14, fontweight='bold')
    plt.tight_layout()
    plot_path = os.path.join(out_dir, 'epsilon_parallel_coordinates.png')
    plt.savefig(plot_path, dpi=300, bbox_inches='tight')
    plt.show()
    print(f"平行坐标图已保存至: {plot_path}")

