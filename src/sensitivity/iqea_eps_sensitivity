def format_mean_std(arr, digits=4):
    arr = np.asarray(arr, dtype=float)
    arr = arr[~np.isnan(arr)]
    if len(arr) == 0:
        return "nan ± nan"
    mean = np.mean(arr)
    std = np.std(arr, ddof=1) if len(arr) > 1 else 0.0
    return f"{mean:.{digits}f} ± {std:.{digits}f}"

def run_epsilon_sensitivity(
        epsilon_settings: List[Tuple[str, float, float]],
        num_runs: int = 20,
        pop_size: int = 30,
        max_iter: int = 100,
        n_obs_base: int = 3,
        base_seed: int = 20260,
        out_dir: str = "epsilon_sensitivity_results",
):
    os.makedirs(out_dir, exist_ok=True)
    run_records: List[Dict[str, Any]] = []
    all_fronts_for_ref: List[Tuple[str, int, List[Tuple[float, float, float]]]] = []
    epsilon_merged_fronts: Dict[str, List[Tuple[float, float, float]]] = {}

    for label, eps_ct, eps_std in epsilon_settings:
        print("=" * 90)
        print(f"[Setting] {label}: EPS_CT={eps_ct}, EPS_STD={eps_std}, EPS_Q=0")
        set_epsilon(eps_ct, eps_std)
        all_points_for_label = []
        for run in range(1, num_runs + 1):
            seed = base_seed + run
            random.seed(seed)
            np.random.seed(seed)
            archive, history, stats = quantum_evolutionary_optimization(
                pop_size=pop_size, max_iter=max_iter, n_obs_base=n_obs_base, verbose=False,
            )
            strict_front = extract_strict_front_from_archive(archive)
            all_fronts_for_ref.append((label, run, strict_front))
            all_points_for_label.extend(strict_front)
            final_sol, final_obj, _ = select_final_solution_majority(archive)
            if final_obj is None:
                ct_f, std_f, ql_f = np.nan, np.nan, np.nan
            else:
                ct_f, std_f, ql_f = final_obj
            run_records.append({
                'label': label, 'run': run, 'EPS_CT': eps_ct, 'EPS_STD': eps_std,
                'CT': ct_f, 'LoadSTD': std_f, 'QLoss': ql_f,
                'runtime_sec': stats['runtime_sec'],
                'objective_evaluations': stats['objective_evaluations'],
                'avg_archive_size': stats['avg_archive_size'],
                'final_archive_size': stats['final_archive_size'],
                'local_improvement_calls': stats['local_improvement_calls'],
                'local_improvement_successes': stats['local_improvement_successes'],
                'local_improvement_evaluations': stats['local_improvement_evaluations'],
                'local_improvement_time_sec': stats['local_improvement_time_sec'],
                'local_time_ratio_pct': stats['local_time_ratio_pct'],
                'avg_local_calls_per_iter': stats['avg_local_calls_per_iter'],
                'local_success_rate_pct': stats['local_success_rate_pct'],
                'strict_front_size': len(strict_front),
                'strict_front': strict_front,
            })
            print(f"  Run {run:02d}/{num_runs:02d} | CT={ct_f:.2f} | STD={std_f:.2f} | Q={ql_f:.4f} | "
                  f"Front={len(strict_front):2d} | Runtime={stats['runtime_sec']:.2f}s")
        if all_points_for_label:
            merged_front = strict_filter_unique(all_points_for_label)
        else:
            merged_front = []
        epsilon_merged_fronts[label] = merged_front
        print(f"  合并后的前沿大小: {len(merged_front)}")

    # Build common reference set
    union_points = []
    for _, _, front in all_fronts_for_ref:
        union_points.extend(front)
    if len(union_points) == 0:
        raise RuntimeError("All strict fronts are empty. Cannot build a reference set.")
    reference_set = strict_filter_unique(union_points)
    mins = np.min(np.asarray(reference_set, dtype=float), axis=0)
    maxs = np.max(np.asarray(reference_set, dtype=float), axis=0)

    # Compute HV/IGD per run
    ref_norm = normalize_points(reference_set, mins, maxs)
    for rec in run_records:
        strict_front = rec['strict_front']
        if len(strict_front) == 0:
            rec['HV'] = np.nan
            rec['IGD'] = np.nan
            continue
        front_norm = normalize_points(strict_front, mins, maxs)
        rec['HV'] = hv_3d_min(front_norm, ref=(1.1, 1.1, 1.1))
        rec['IGD'] = igd(front_norm, ref_norm)

    # Save run-level CSV
    run_csv = os.path.join(out_dir, 'epsilon_sensitivity_run_details.csv')
    with open(run_csv, 'w', newline='', encoding='utf-8-sig') as f:
        writer = csv.writer(f)
        writer.writerow([
            'label', 'run', 'EPS_CT', 'EPS_STD',
            'CT', 'LoadSTD', 'QLoss', 'HV', 'IGD',
            'runtime_sec', 'objective_evaluations',
            'avg_archive_size', 'final_archive_size', 'strict_front_size',
            'local_improvement_calls', 'local_improvement_successes',
            'local_improvement_evaluations', 'local_improvement_time_sec',
            'local_time_ratio_pct', 'avg_local_calls_per_iter', 'local_success_rate_pct'
        ])
        for rec in run_records:
            writer.writerow([
                rec['label'], rec['run'], rec['EPS_CT'], rec['EPS_STD'],
                rec['CT'], rec['LoadSTD'], rec['QLoss'], rec['HV'], rec['IGD'],
                rec['runtime_sec'], rec['objective_evaluations'],
                rec['avg_archive_size'], rec['final_archive_size'], rec['strict_front_size'],
                rec['local_improvement_calls'], rec['local_improvement_successes'],
                rec['local_improvement_evaluations'], rec['local_improvement_time_sec'],
                rec['local_time_ratio_pct'], rec['avg_local_calls_per_iter'], rec['local_success_rate_pct']
            ])

    # Summary table
    summary_rows = []
    for label, eps_ct, eps_std in epsilon_settings:
        subset = [r for r in run_records if r['label'] == label]
        row = {
            'label': label, 'EPS_CT': eps_ct, 'EPS_STD': eps_std,
            'CT_mean_std': format_mean_std([r['CT'] for r in subset], 2),
            'LoadSTD_mean_std': format_mean_std([r['LoadSTD'] for r in subset], 2),
            'QLoss_mean_std': format_mean_std([r['QLoss'] for r in subset], 4),
            'HV_mean_std': format_mean_std([r['HV'] for r in subset], 4),
            'IGD_mean_std': format_mean_std([r['IGD'] for r in subset], 4),
            'Runtime_mean_std': format_mean_std([r['runtime_sec'] for r in subset], 2),
            'ObjEval_mean_std': format_mean_std([r['objective_evaluations'] for r in subset], 1),
            'AvgArchive_mean_std': format_mean_std([r['avg_archive_size'] for r in subset], 2),
            'FinalArchive_mean_std': format_mean_std([r['final_archive_size'] for r in subset], 2),
            'LocalCalls_mean_std': format_mean_std([r['local_improvement_calls'] for r in subset], 2),
            'LocalTimePct_mean_std': format_mean_std([r['local_time_ratio_pct'] for r in subset], 2),
            'LocalSuccessPct_mean_std': format_mean_std([r['local_success_rate_pct'] for r in subset], 2),
        }
        summary_rows.append(row)

    summary_csv = os.path.join(out_dir, 'epsilon_sensitivity_summary.csv')
    with open(summary_csv, 'w', newline='', encoding='utf-8-sig') as f:
        writer = csv.writer(f)
        writer.writerow([
            'label', 'EPS_CT', 'EPS_STD',
            'CT (mean±std)', 'LoadSTD (mean±std)', 'QLoss (mean±std)',
            'HV (mean±std)', 'IGD (mean±std)',
            'Runtime_s (mean±std)', 'ObjectiveEvaluations (mean±std)',
            'AvgArchiveSize (mean±std)', 'FinalArchiveSize (mean±std)',
            'LocalImprovementCalls (mean±std)', 'LocalTimeRatioPct (mean±std)',
            'LocalSuccessRatePct (mean±std)'
        ])
        for row in summary_rows:
            writer.writerow([
                row['label'], row['EPS_CT'], row['EPS_STD'],
                row['CT_mean_std'], row['LoadSTD_mean_std'], row['QLoss_mean_std'],
                row['HV_mean_std'], row['IGD_mean_std'],
                row['Runtime_mean_std'], row['ObjEval_mean_std'],
                row['AvgArchive_mean_std'], row['FinalArchive_mean_std'],
                row['LocalCalls_mean_std'], row['LocalTimePct_mean_std'],
                row['LocalSuccessPct_mean_std'],
            ])

    # Reference details
    norm_csv = os.path.join(out_dir, 'epsilon_reference_details.csv')
    with open(norm_csv, 'w', newline='', encoding='utf-8-sig') as f:
        writer = csv.writer(f)
        writer.writerow(['Metric', 'Value'])
        writer.writerow(['ReferenceSetSize', len(reference_set)])
        writer.writerow(['CT_min', float(mins[0])])
        writer.writerow(['CT_max', float(maxs[0])])
        writer.writerow(['LoadSTD_min', float(mins[1])])
        writer.writerow(['LoadSTD_max', float(maxs[1])])
        writer.writerow(['QLoss_min', float(mins[2])])
        writer.writerow(['QLoss_max', float(maxs[2])])
        writer.writerow(['HV_reference_point', '(1.1, 1.1, 1.1)'])
        writer.writerow(['IGD_reference_set_construction',
                         'Union of strict nondominated fronts from all epsilon settings and all runs'])

    # Generate plots
    epsilon_labels = [label for label, _, _ in epsilon_settings]
    plot_epsilon_sensitivity_clouds(epsilon_merged_fronts, epsilon_labels, out_dir)
    plot_hv_igd_boxplots(run_records, epsilon_labels, out_dir)
    plot_parallel_coordinates(run_records, epsilon_labels, out_dir)

    print("\n" + "#" * 90)
    print("ε-sensitivity summary (directly usable for the paper)")
    for row in summary_rows:
        print(
            f"{row['label']} | ε=({row['EPS_CT']}, {row['EPS_STD']}, 0) | "
            f"HV={row['HV_mean_std']} | IGD={row['IGD_mean_std']} | "
            f"Runtime={row['Runtime_mean_std']} | AvgArchive={row['AvgArchive_mean_std']}"
        )
    print("#" * 90)
    print(f"Run-level CSV   : {run_csv}")
    print(f"Summary CSV     : {summary_csv}")
    print(f"Reference details: {norm_csv}")

    return {
        'run_records': run_records,
        'summary_rows': summary_rows,
        'reference_set': reference_set,
        'normalization_bounds': {'mins': mins, 'maxs': maxs},
        'run_csv': run_csv,
        'summary_csv': summary_csv,
        'norm_csv': norm_csv,
        'epsilon_merged_fronts': epsilon_merged_fronts,
    }


